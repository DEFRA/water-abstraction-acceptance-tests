{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "▶️ Open cypress (Tests)",
      "detail": "Open Cypress test UI to manually run its tests",
      "type": "shell",
      "command": "npm run cy:open:${input:environments}; echo 'All done! 🎉'",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "📺 Open playwright (Tests)",
      "detail": "Open Playwright test UI to manually run its tests",
      "type": "shell",
      "command": "npm run pw:open:local; echo 'All done! 🎉'",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "⏩️ Run all (Tests)",
      "detail": "Run Cypress then Playwright tests headless using the runner",
      "type": "shell",
      "command": "npm run test:local; echo 'All done! 🎉'",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "➡️ Run cypress (Tests)",
      "detail": "Run Cypress tests headless using the runner",
      "type": "shell",
      "command": "npm run cy:run:${input:environments}; echo 'All done! 🎉'",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "📻 Run playwright (Tests)",
      "detail": "Run Playwright tests headless using the runner",
      "type": "shell",
      "command": "npm run pw:run:local; echo 'All done! 🎉'",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "🔍 Lint (Tests)",
      "detail": "Run linting for system",
      "type": "shell",
      "command": "npm run lint; echo 'All done! 🎉'",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "👷 Build (Tests)",
      "detail": "Run npm ci",
      "type": "shell",
      "command": "npm ci; echo 'All done! 🎉'",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "👍 Verify cypress (Tests)",
      "detail": "Verify that Cypress is installed correctly",
      "type": "shell",
      "command": "npm run cy:verify",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "🌱 Seed (Tests)",
      "detail": "Launch the seed cli to manually load test data",
      "type": "shell",
      "command": "npm run cli:seed",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    }
  ],
  "inputs": [
    {
      "id": "environments",
      "description": "Environments",
      "type": "pickString",
      "options": [
        "local",
        "dev",
        "tst",
        "pre"
      ]
    }
  ]
}
